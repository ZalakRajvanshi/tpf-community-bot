# Slack credentials — copy this file to `.env` and fill in real values.
# Never commit the real .env file.

# Bot User OAuth Token (starts with xoxb-) from OAuth & Permissions.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret from Basic Information > App Credentials.
SLACK_SIGNING_SECRET=your-signing-secret

# Slack user ID of the Human POC who receives all DMs (new-member alerts +
# daily digest). Find it via the member's profile > "Copy member ID" (U...).
HUMAN_POC_USER_ID=U0XXXXXXX

# Shared secret protecting the /tasks/daily-digest trigger. If unset, the
# endpoint is open (use only for local testing).
DIGEST_TRIGGER_TOKEN=change-me

# How many hours of history the digest covers (optional, default 24).
DIGEST_WINDOW_HOURS=24

# Where the SQLite file lives (optional, default bot_data.db).
DB_PATH=bot_data.db

# Local dev port (optional; Render sets PORT automatically).
PORT=3000
