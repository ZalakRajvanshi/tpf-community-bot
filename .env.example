# Slack credentials — copy this file to `.env` and fill in real values.
# Never commit the real .env file.

# Bot User OAuth Token (starts with xoxb-) from OAuth & Permissions.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret from Basic Information > App Credentials.
SLACK_SIGNING_SECRET=your-signing-secret

# Slack user ID of the Human POC who receives the daily report (U...).
# Find it via the member's profile > "Copy member ID".
HUMAN_POC_USER_ID=U0XXXXXXX

# Shared secret protecting the /tasks/* endpoints. If unset, they're open
# (use only for local testing).
DIGEST_TRIGGER_TOKEN=change-me

# How many hours of history the daily report covers (optional, default 24).
DAILY_WINDOW_HOURS=24

# --- AI understanding (OPTIONAL) ------------------------------------------
# If set, the report uses OpenAI to judge whether messages fit their channel
# and whether they need a reply (smarter than keywords). Used only at report
# time and batched to keep token use low. Leave OPENAI_API_KEY blank to use
# the keyword heuristics instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_CLASSIFICATION=on
AI_BATCH_SIZE=40

# Where the SQLite file lives (optional, default bot_data.db).
DB_PATH=bot_data.db

# Local dev port (optional; Render sets PORT automatically).
PORT=3000
