# Slack credentials — copy this file to `.env` and fill in real values.
# Never commit the real .env file.

# Bot User OAuth Token (starts with xoxb-) from OAuth & Permissions.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret from Basic Information > App Credentials.
SLACK_SIGNING_SECRET=your-signing-secret

# Local dev port (optional; Render sets PORT automatically).
PORT=3000
